{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"composite": true,
		"declaration": true,
		"esModuleInterop": true,
		"lib": ["dom", "es2021"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmitOnError": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"outDir": "lib",
		"resolveJsonModule": true,
		"rootDir": "src",
		"strict": true,
		"target": "es2021"
	},
	"include": ["src/**/*"]
}
